      "id": "fetch-leads-to-email",
      "name": "Fetch Leads Ready for Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        500
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.all().map(i => i.json);\nconst allLeads = Array.isArray(leads[0]) ? leads[0] : leads;\nconst now = new Date();\nconst results = [];\n\nfor (const lead of allLeads) {\n  if (!lead.email || !lead.status) continue;\n\n  const lastContacted = lead.last_contacted_at ? new Date(lead.last_contacted_at) : null;\n  const daysSinceContact = lastContacted ? Math.floor((now - lastContacted) / (1000 * 60 * 60 * 24)) : 999;\n\n  let emailType = null;\n  let newStatus = null;\n\n  if (lead.status === 'new') {\n    emailType = 'initial';\n    newStatus = 'contacted';\n  } else if (lead.status === 'follow_up_1' && daysSinceContact >= 3) {\n    emailType = 'follow_up_1';\n    newStatus = 'follow_up_2';\n  } else if (lead.status === 'follow_up_2' && daysSinceContact >= 7) {\n    emailType = 'follow_up_2';\n    newStatus = 'completed';\n  }\n\n  if (emailType) {\n    results.push({\n      json: {\n        id: lead.id,\n        business_name: lead.business_name,\n        email: lead.email,\n        first_name: lead.first_name || '',\n        city: lead.city || '',\n        state: lead.state || '',\n        status: lead.status,\n        emailType,\n        newStatus\n      }\n    });\n  }\n}\n\nif (results.length === 0) {\n  return [{ json: { _skip: true, reason: 'No leads ready for email today' } }];\n}\n\n// Enforce 30/day rate limit\nreturn results.slice(0, 30);"
      },
