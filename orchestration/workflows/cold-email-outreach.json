    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst results = response.local_results || response.place_results || [];\n\nconst leads = results.map(r => {\n  const name = r.title || r.name || '';\n  const address = r.address || '';\n  const phone = r.phone || '';\n  const website = r.website || '';\n  const city = (address.split(',')[1] || '').trim();\n  const state = (address.split(',')[2] || '').trim().split(' ')[0] || '';\n\n  // Extract domain from website URL\n  let domain = '';\n  if (website) {\n    try {\n      domain = new URL(website.startsWith('http') ? website : 'https://' + website).hostname.replace('www.', '');\n    } catch (e) {\n      domain = website.replace(/^https?:\\/\\//, '').replace(/^www\\./, '').split('/')[0];\n    }\n  }\n\n  return {\n    json: {\n      business_name: name,\n      address,\n      phone,\n      website,\n      domain,\n      city,\n      state,\n      source: 'google_maps'\n    }\n  };\n}).filter(l => l.json.domain);\n\nif (leads.length === 0) {\n  return [{ json: { _empty: true, reason: 'No leads with websites found' } }];\n}\n\nreturn leads;"
      },
