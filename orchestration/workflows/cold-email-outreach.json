    {
      "parameters": {
        "jsCode": "const hunterResponse = $input.first().json;\nconst leadData = $('Extract Lead Data').first().json;\n\n// Get best email from Hunter response\nconst data = hunterResponse.data || {};\nconst emails = data.emails || [];\n\nlet bestEmail = '';\nlet firstName = '';\nlet lastName = '';\n\nif (emails.length > 0) {\n  // Prefer emails with high confidence, owner/manager type\n  const sorted = emails.sort((a, b) => (b.confidence || 0) - (a.confidence || 0));\n  const best = sorted[0];\n  bestEmail = best.value || '';\n  firstName = best.first_name || '';\n  lastName = best.last_name || '';\n}\n\nif (!bestEmail) {\n  return [{ json: { _skip: true, reason: 'No email found', business_name: leadData.business_name } }];\n}\n\nreturn [{\n  json: {\n    business_name: leadData.business_name,\n    email: bestEmail,\n    first_name: firstName,\n    last_name: lastName,\n    phone: leadData.phone,\n    website: leadData.website,\n    city: leadData.city,\n    state: leadData.state,\n    source: leadData.source\n  }\n}];"
      },
