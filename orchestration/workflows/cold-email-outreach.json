    {
      "parameters": {
        "jsCode": "const emailData = $('Build Personalized Email').first().json;\nconst resendResponse = $input.first().json;\nconst sent = !!(resendResponse.id);\n\nlet newStatus = emailData.newStatus;\n\n// If it was the initial email and it was sent, set to follow_up_1 (waiting for follow-up)\nif (emailData.emailType === 'initial' && sent) {\n  newStatus = 'follow_up_1';\n} else if (emailData.emailType === 'follow_up_1' && sent) {\n  newStatus = 'follow_up_2';\n} else if (emailData.emailType === 'follow_up_2' && sent) {\n  newStatus = 'completed';\n}\n\nreturn [{\n  json: {\n    id: emailData.id,\n    email: emailData.email,\n    emailType: emailData.emailType,\n    newStatus: sent ? newStatus : emailData.status,\n    sent,\n    resendId: resendResponse.id || null,\n    error: resendResponse.error || null\n  }\n}];"
      },
