      "parameters": {
        "jsCode": "const verifyResponse = $input.first().json;\nconst leadData = $('Extract Best Email').first().json;\n\n// MillionVerifier returns { result: 'ok' | 'catch_all' | 'invalid' | 'disposable' | 'unknown', ... }\nconst result = (verifyResponse.result || '').toLowerCase();\nconst quality = (verifyResponse.quality || '').toLowerCase();\n\n// Accept 'ok' and 'catch_all', reject everything else\nconst acceptable = ['ok', 'catch_all'];\n\nif (!acceptable.includes(result)) {\n  return [{\n    json: {\n      _skip: true,\n      reason: 'Email validation failed: ' + result,\n      email: leadData.email,\n      business_name: leadData.business_name\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...leadData,\n    email_verified: true,\n    email_verify_result: result\n  }\n}];"
      },
