    {
      "parameters": {
        "jsCode": "const payload = $input.first().json.body || $input.first().json;\n\n// Parse inbound email webhook (Resend / generic format)\nconst fromEmail = payload.from || payload.sender || payload.envelope?.from || '';\nconst subject = payload.subject || '';\nconst body = payload.text || payload.plain || payload.html || '';\nconst replyDate = new Date().toISOString();\n\n// Unsubscribe detection (CAN-SPAM compliance)\nconst unsubscribeKeywords = ['unsubscribe', 'remove me', 'stop emailing', 'opt out', 'opt-out', 'take me off', 'remove my email'];\nconst bodyLower = body.toLowerCase();\nconst subjectLower = subject.toLowerCase();\nconst isUnsubscribe = unsubscribeKeywords.some(kw => bodyLower.includes(kw) || subjectLower.includes(kw));\n\nif (isUnsubscribe) {\n  return [{\n    json: {\n      fromEmail: fromEmail.replace(/<|>/g, '').trim(),\n      subject,\n      body: body.substring(0, 2000),\n      sentiment: 'unsubscribe',\n      isUnsubscribe: true,\n      replyDate\n    }\n  }];\n}\n\n// Standard sentiment detection for non-unsubscribe replies\nconst positiveKeywords = ['interested', 'yes', 'sure', 'tell me more', 'demo', 'try', 'sign up', 'pricing', 'sounds good', 'let\\'s talk', 'schedule', 'call me'];\nconst negativeKeywords = ['not interested', 'no thanks', 'no thank', 'pass', 'not for us'];\n\nlet sentiment = 'neutral';\n\nif (positiveKeywords.some(kw => bodyLower.includes(kw))) {\n  sentiment = 'positive';\n} else if (negativeKeywords.some(kw => bodyLower.includes(kw))) {\n  sentiment = 'negative';\n}\n\nreturn [{\n  json: {\n    fromEmail: fromEmail.replace(/<|>/g, '').trim(),\n    subject,\n    body: body.substring(0, 2000),\n    sentiment,\n    isUnsubscribe: false,\n    replyDate\n  }\n}];"
      },
