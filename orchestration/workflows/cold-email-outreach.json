    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst { business_name, first_name, city, emailType } = lead;\nconst name = first_name || 'there';\n\nconst signature = 'Best,\\nShalin\\nFounder, BayFlow\\nshalin@bayflow.com';\n\n// CAN-SPAM compliance footer (required on all commercial emails)\nconst canSpamFooter = '\\n\\nBayFlow | [Physical Address TBD] | bayflow.com\\n\\nDon\\'t want to hear from us? Reply \\'unsubscribe\\' and we\\'ll remove you immediately.';\n\nconst templates = {\n  initial: {\n    subject: `Quick question about ${business_name}`,\n    text: `Hi ${name},\\n\\nI noticed ${business_name} is running repairs in ${city}. Are you still using paper tickets or a generic system to track repair orders?\\n\\nWe built BayFlow specifically for independent auto repair shops. It handles scheduling, digital inspections (with photos your customers can see), invoicing, and customer management. Shops using it say they save about 5 hours a week on paperwork.\\n\\nIt's $49/month and you can try it free for 14 days. No credit card needed.\\n\\nWorth a look? Here's a 2-minute demo: https://bayflow.com/demo\\n\\n${signature}${canSpamFooter}`\n  },\n  follow_up_1: {\n    subject: `Re: Quick question about ${business_name}`,\n    text: `Hey ${name},\\n\\nJust bumping this up. Wanted to make sure you saw it.\\n\\nBayFlow's digital inspection feature alone is worth checking out. Your techs snap photos of worn parts, customer gets a text with the photos, and they approve the work right from their phone. Shops see 89% approval rates on recommended services.\\n\\n14-day free trial: https://bayflow.com\\n\\n${signature}${canSpamFooter}`\n  },\n  follow_up_2: {\n    subject: 'Should I close your file?',\n    text: `Hi ${name},\\n\\nI've reached out a couple times about BayFlow for ${business_name}. I don't want to be annoying, so this is my last email.\\n\\nIf you're ever looking for shop management software built specifically for independent repair shops, we're at bayflow.com.\\n\\nGood luck with everything.\\n\\n${signature}${canSpamFooter}`\n  }\n};\n\nconst template = templates[emailType];\n\nreturn [{\n  json: {\n    ...lead,\n    emailSubject: template.subject,\n    emailText: template.text\n  }\n}];"
      },
      "id": "build-cold-email",
      "name": "Build Personalized Email",
      "type": "n8n-nodes-base.code",
