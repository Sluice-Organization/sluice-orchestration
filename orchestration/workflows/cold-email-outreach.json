    {
      "parameters": {
        "jsCode": "const leadData = $input.first().json;\n\n// DNC Check placeholder - flags phone numbers for later DNCScrub API integration\n// For now, we flag leads based on basic phone number heuristics\n\nconst phone = (leadData.phone || '').replace(/[^0-9]/g, '');\n\n// Common US mobile area codes (non-exhaustive, used as a heuristic)\nconst mobileAreaCodes = [\n  '201','202','203','206','207','208','209','210','212','213','214','215',\n  '216','217','218','219','224','225','228','229','231','234','239','240',\n  '248','251','252','253','254','256','260','262','267','269','270','272',\n  '276','281','301','302','303','304','305','307','308','309','310','312',\n  '313','314','315','316','317','318','319','320','321','323','325','330',\n  '331','334','336','337','339','346','347','351','352','360','361','364',\n  '380','385','386','401','402','404','405','406','407','408','409','410',\n  '412','413','414','415','417','419','423','424','425','430','432','434',\n  '435','440','442','443','458','469','470','475','478','479','480','484',\n  '501','502','503','504','505','507','508','509','510','512','513','515',\n  '516','517','518','520','530','531','534','539','540','541','551','559',\n  '561','562','563','567','570','571','573','574','575','580','585','586'\n];\n\nlet phoneType = 'unknown';\nlet dncChecked = false;\n\nif (!phone || phone.length < 10) {\n  phoneType = 'empty_or_invalid';\n} else {\n  const areaCode = phone.length === 11 && phone.startsWith('1') ? phone.substring(1, 4) : phone.substring(0, 3);\n  if (mobileAreaCodes.includes(areaCode)) {\n    phoneType = 'likely_mobile';\n  } else {\n    phoneType = 'likely_landline';\n  }\n}\n\n// TODO: Replace with actual DNCScrub API integration\n// API endpoint: https://api.dncscrub.com/v1/check\n// When configured, set dnc_checked = true and add dnc_status field\n\nreturn [{\n  json: {\n    ...leadData,\n    phone_type: phoneType,\n    dnc_checked: dncChecked\n  }\n}];"
      },
