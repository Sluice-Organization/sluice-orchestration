      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [3300, 220]
    },
    {
      "parameters": {
        "jsCode": "const llmOutput = $('Comptroller LLM Chain').first().json.text || '';\nconst businessId = $('Merge Context').first().json.businessId;\nconst businessPath = $('Merge Context').first().json.businessPath;\nconst weeklyPlanSha = $('Merge Context').first().json.weeklyPlanSha;\n\n// Determine verdict\nconst rejected = llmOutput.includes('REJECTED');\n\n// Extract revised plan if rejected\nlet revisedPlan = '';\nif (rejected) {\n  const startMarker = '===REVISED_PLAN_START===';\n  const endMarker = '===REVISED_PLAN_END===';\n  const startIdx = llmOutput.indexOf(startMarker);\n  const endIdx = llmOutput.indexOf(endMarker);\n  if (startIdx !== -1 && endIdx !== -1) {\n    revisedPlan = llmOutput.substring(startIdx + startMarker.length, endIdx).trim();\n  }\n}\n\nreturn [{\n  json: {\n    verdict: rejected ? 'REJECTED' : 'APPROVED',\n    rejected,\n    revisedPlan,\n    reviewText: llmOutput,\n    businessId,\n    businessPath,\n    weeklyPlanSha\n  }\n}];"
      },
