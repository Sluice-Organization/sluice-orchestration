      "parameters": {
        "jsCode": "const today = new Date();\nconst yyyy = today.getFullYear();\nconst mm = String(today.getMonth() + 1).padStart(2, '0');\nconst dd = String(today.getDate()).padStart(2, '0');\nconst todayStr = `${yyyy}-${mm}-${dd}`;\n\n// Yesterday\nconst yesterday = new Date(today);\nyesterday.setDate(yesterday.getDate() - 1);\nconst yy = yesterday.getFullYear();\nconst ym = String(yesterday.getMonth() + 1).padStart(2, '0');\nconst yd = String(yesterday.getDate()).padStart(2, '0');\nconst yesterdayStr = `${yy}-${ym}-${yd}`;\n\nconst businessPath = $('Filter Active Businesses').first().json.businessPath;\n\nreturn [{\n  json: {\n    todayStr,\n    yesterdayStr,\n    businessPath,\n    ceoReportPathToday: `${businessPath}/reports/ceo-${todayStr}.md`,\n    ceoReportPathYesterday: `${businessPath}/reports/ceo-${yesterdayStr}.md`,\n    financeReportPathToday: `${businessPath}/reports/finance-${todayStr}.md`,\n    financeReportPathYesterday: `${businessPath}/reports/finance-${yesterdayStr}.md`,\n    contentReportPathToday: `${businessPath}/reports/content-${todayStr}.md`,\n    contentReportPathYesterday: `${businessPath}/reports/content-${yesterdayStr}.md`\n  }\n}];"
      },
