    {
      "parameters": {
        "jsCode": "// Collect all action results from all branches\nconst allItems = $input.all();\nconst results = allItems.map(item => ({\n  actionType: item.json.actionType || 'UNKNOWN',\n  success: item.json.success !== false,\n  message: item.json.message || 'No message'\n}));\n\nconst businessId = allItems[0]?.json?.businessId || 'unknown';\nconst today = new Date().toISOString().split('T')[0];\n\nconst logContent = `# CEO Action Execution Log - ${today}\\n\\n` +\n  `**Business:** ${businessId}\\n` +\n  `**Executed at:** ${new Date().toISOString()}\\n` +\n  `**Total actions:** ${results.length}\\n\\n` +\n  `## Actions Executed\\n\\n` +\n  results.map((r, i) => `### ${i + 1}. ${r.actionType}\\n- **Status:** ${r.success ? 'SUCCESS' : 'FAILED'}\\n- **Details:** ${r.message}\\n`).join('\\n') +\n  `\\n---\\n*Generated by CEO Action Executor*\\n`;\n\nconst summary = results.map(r => `${r.success ? 'OK' : 'FAIL'} ${r.actionType}: ${r.message}`).join('\\n');\n\nreturn [{\n  json: {\n    businessId,\n    today,\n    logContent,\n    summary,\n    totalActions: results.length,\n    successCount: results.filter(r => r.success).length,\n    results\n  }\n}];"
