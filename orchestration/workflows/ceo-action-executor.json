      "parameters": {
        "jsCode": "const params = $json.params;\nconst regions = params.regions || ['california'];\nconst queries = params.queries || ['auto repair shop'];\n\nconst combos = [];\nfor (const region of regions) {\n  for (const query of queries) {\n    combos.push({\n      json: {\n        businessId: $json.businessId,\n        actionType: $json.actionType,\n        region,\n        query,\n        searchQuery: `${query} in ${region}`\n      }\n    });\n  }\n}\nreturn combos;"
      },
