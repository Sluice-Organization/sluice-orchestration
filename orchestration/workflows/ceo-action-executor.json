{
  "name": "CEO Action Executor",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ceo-actions",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook POST /ceo-actions",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "ceo-actions"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst businessId = body.businessId || 'unknown';\nconst actions = body.actions || [];\n\nconst validTypes = [\n  'EXPAND_LEAD_GEN', 'ACTIVATE_GOOGLE_ADS', 'SCALE_COLD_EMAIL',\n  'INCREASE_CONTENT', 'ADJUST_PRICING', 'LAUNCH_BUSINESS',\n  'KILL_BUSINESS', 'ACTIVATE_META_ADS', 'INCREASE_CALL_VOLUME',\n  'REQUEST_HUMAN_DECISION'\n];\n\nconst validatedActions = [];\nconst errors = [];\n\nfor (let i = 0; i < actions.length; i++) {\n  const action = actions[i];\n  if (!action.type || !validTypes.includes(action.type)) {\n    errors.push(`Action ${i}: invalid type '${action.type}'`);\n    continue;\n  }\n  if (!action.params || typeof action.params !== 'object') {\n    errors.push(`Action ${i}: missing or invalid params`);\n    continue;\n  }\n  validatedActions.push({\n    json: {\n      businessId,\n      actionIndex: i,\n      actionType: action.type,\n      params: action.params,\n      totalActions: actions.length\n    }\n  });\n}\n\nif (validatedActions.length === 0 && errors.length > 0) {\n  return [{ json: { businessId, error: true, errors, actionType: 'NONE', params: {} } }];\n}\n\nif (validatedActions.length === 0) {\n  return [{ json: { businessId, error: false, actionType: 'NONE', params: {}, message: 'No actions to execute' } }];\n}\n\nreturn validatedActions;"
      },
      "id": "parse-actions",
      "name": "Parse & Validate Actions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "outputIndex": 0,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "EXPAND_LEAD_GEN", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 1,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "ACTIVATE_GOOGLE_ADS", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 2,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "SCALE_COLD_EMAIL", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 3,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "INCREASE_CONTENT", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 4,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "ADJUST_PRICING", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 5,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "LAUNCH_BUSINESS", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 6,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "KILL_BUSINESS", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 7,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "ACTIVATE_META_ADS", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 8,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "INCREASE_CALL_VOLUME", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputIndex": 9,
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.actionType }}", "rightValue": "REQUEST_HUMAN_DECISION", "operator": { "type": "string", "operation": "equals" } }]
              }
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "route-action-type",
      "name": "Route by Action Type",
      "type": "n8n-nodes-base.switch",
