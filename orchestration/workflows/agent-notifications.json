    {
      "parameters": {
        "jsCode": "const text = $json.message?.text || '';\nconst textLower = text.toLowerCase().trim();\n\n// Structured commands\nif (textLower.startsWith('update ')) {\n  const parts = text.split(' ');\n  if (parts.length >= 4) {\n    const business = parts[1];\n    const email = parts[2];\n    const action = parts[3];\n    return [{ json: { intent: 'UPDATE_LEAD', action, email, businessId: business, raw: text } }];\n  }\n}\n\nif (textLower.startsWith('converted ')) {\n  const email = text.split(' ')[1];\n  return [{ json: { intent: 'UPDATE_LEAD', action: 'converted', email, raw: text } }];\n}\n\nif (textLower.startsWith('demo completed ')) {\n  const parts = text.split(' ');\n  const email = parts[2];\n  const notes = parts.slice(3).join(' ');\n  return [{ json: { intent: 'DEMO_COMPLETED', email, notes, raw: text } }];\n}\n\nif (textLower.startsWith('rejected ')) {\n  const email = text.split(' ')[1];\n  return [{ json: { intent: 'UPDATE_LEAD', action: 'rejected', email, raw: text } }];\n}\n\nif (textLower.startsWith('pause ')) {\n  const businessId = text.split(' ')[1];\n  return [{ json: { intent: 'PAUSE_BUSINESS', businessId, raw: text } }];\n}\n\nif (textLower.startsWith('resume ')) {\n  const businessId = text.split(' ')[1];\n  return [{ json: { intent: 'RESUME_BUSINESS', businessId, raw: text } }];\n}\n\nif (textLower.startsWith('kill ')) {\n  const businessId = text.split(' ')[1];\n  return [{ json: { intent: 'KILL_BUSINESS', businessId, raw: text } }];\n}\n\nif (textLower === 'status') {\n  return [{ json: { intent: 'STATUS_REQUEST', raw: text } }];\n}\n\nif (textLower === 'help') {\n  return [{ json: { intent: 'HELP', raw: text } }];\n}\n\n// Freeform message \u2014 route to CEO Agent for interpretation\n// Try to detect if a known business is referenced\nconst knownBusinesses = ['bayflow', 'yogaflow', 'petcare'];\nlet detectedBusiness = null;\nfor (const biz of knownBusinesses) {\n  if (textLower.includes(biz)) {\n    detectedBusiness = biz;\n    break;\n  }\n}\n\nreturn [{ json: { intent: 'FREEFORM', raw: text, detectedBusiness } }];"
      },
