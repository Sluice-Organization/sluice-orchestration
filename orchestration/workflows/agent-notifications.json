      "id": "fetch-status",
      "name": "Fetch All Business Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 1500],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const businesses = $input.first().json;\nconst data = Array.isArray(businesses) ? businesses : [businesses];\n\nlet activeCount = 0;\nlet lines = [];\n\nfor (const biz of data) {\n  if (!biz || !biz.business_id) continue;\n  activeCount++;\n  const mrr = biz.mrr ? `$${Number(biz.mrr).toLocaleString()}` : '$0';\n  const customers = biz.customer_count || 0;\n  const leads = biz.leads_in_pipeline || 0;\n  const status = biz.status || 'unknown';\n  lines.push(`*${biz.business_id}*: ${mrr} MRR | ${customers} customers | ${leads} leads (${status})`);\n}\n\nif (lines.length === 0) {\n  lines.push('No businesses found in system_context.');\n}\n\nconst summary = `\\ud83d\\udcca *Forge Status*\\n\\nActive businesses: ${activeCount}\\n\\n${lines.join('\\n')}\\n\\n_Updated: ${new Date().toISOString().replace('T', ' ').substring(0, 19)} UTC_`;\n\nreturn [{ json: { statusMessage: summary } }];"
      },
      "id": "format-status",
      "name": "Format Status Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1550, 1500]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.statusMessage }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-status",
      "name": "Send Status",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1800, 1500],
      "credentials": {
        "telegramApi": {
          "id": "telegram-cred",
          "name": "Telegram Bot"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "\ud83e\udd16 *Forge Agent Commands:*\n\n*Sales:*\n\u2022 `converted [email]` \u2014 Mark lead as converted\n\u2022 `demo completed [email] [notes]` \u2014 Log demo outcome\n\u2022 `rejected [email]` \u2014 Mark lead as not interested\n\n*Business:*\n\u2022 `pause [business_id]` \u2014 Pause all operations\n\u2022 `resume [business_id]` \u2014 Resume operations\n\u2022 `kill [business_id]` \u2014 Trigger death protocol\n\u2022 `status` \u2014 Get full pipeline summary\n\n*General:*\n\u2022 Any other message is forwarded to the CEO Agent\n\n*Examples:*\n`converted john@joeauto.com`\n`demo completed mike@shop.com loved the inspection feature`\n`pause yogaflow`\n`status`",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-help",
      "name": "Send Help",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1300, 1650],
      "credentials": {
        "telegramApi": {
          "id": "telegram-cred",
          "name": "Telegram Bot"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.raw || '';\nconst detectedBusiness = $json.detectedBusiness || null;\nconst now = new Date();\nconst dateStr = now.toISOString().substring(0, 10);\nconst timestamp = now.toISOString().replace('T', ' ').substring(0, 19) + ' UTC';\n\n// File for memory-bank\nconst fileName = `${dateStr}.md`;\nconst filePath = `memory-bank/system/human-feedback/${fileName}`;\nconst fileContent = `# Human Feedback - ${dateStr}\\n\\n- **Timestamp**: ${timestamp}\\n- **Message**: ${raw}\\n- **Detected Business**: ${detectedBusiness || 'none'}\\n`;\n\n// GitHub issue\nconst issueTitle = `Human feedback: ${raw.substring(0, 60)}${raw.length > 60 ? '...' : ''}`;\nconst issueBody = `## Human Message\\n\\n> ${raw}\\n\\n- **Received**: ${timestamp}\\n- **Detected Business**: ${detectedBusiness || 'none'}\\n\\nThis message was sent via Telegram and needs CEO Agent review.`;\nconst issueRepo = detectedBusiness ? `sluice-${detectedBusiness}` : 'sluice-orchestration';\n\nreturn [{\n  json: {\n    raw,\n    detectedBusiness,\n    filePath,\n    fileContent: Buffer.from(fileContent).toString('base64'),\n    issueTitle,\n    issueBody,\n    issueRepo\n  }\n}];"
      },
