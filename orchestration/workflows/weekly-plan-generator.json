    {
      "parameters": {
        "jsCode": "const now = new Date();\n\n// Find last Monday (the start of the reporting week)\nconst dayOfWeek = now.getDay(); // Sunday = 0\n// Today is Sunday, so last Monday is 6 days ago\nconst lastMonday = new Date(now);\nlastMonday.setDate(now.getDate() - 6);\nconst lastMondayStr = lastMonday.toISOString().split('T')[0];\n\n// Last Tuesday\nconst lastTuesday = new Date(lastMonday);\nlastTuesday.setDate(lastMonday.getDate() + 1);\nconst lastTuesdayStr = lastTuesday.toISOString().split('T')[0];\n\n// Last Friday\nconst lastFriday = new Date(lastMonday);\nlastFriday.setDate(lastMonday.getDate() + 4);\nconst lastFridayStr = lastFriday.toISOString().split('T')[0];\n\n// Last Saturday\nconst lastSaturday = new Date(lastMonday);\nlastSaturday.setDate(lastMonday.getDate() + 5);\nconst lastSaturdayStr = lastSaturday.toISOString().split('T')[0];\n\nconst today = now.toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    today,\n    lastMonday: lastMondayStr,\n    lastTuesday: lastTuesdayStr,\n    lastFriday: lastFridayStr,\n    lastSaturday: lastSaturdayStr,\n    businessPath: $input.first().json.businessPath || ('memory-bank/businesses/' + ($input.first().json.businessId || 'bayflow')),\n    businessId: $input.first().json.businessId || 'bayflow'\n  }\n}];"
      },
