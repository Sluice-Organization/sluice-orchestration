      "id": "read-current-plan",
      "name": "Read Current Weekly Plan",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [2640, 0]
    },
    {
      "parameters": {
        "jsCode": "const dates = $('Compute Dates').first().json;\n\n// Core context (always exist)\nconst state = $('Read State').first().json.content || '';\nconst strategy = $('Read Strategy').first().json.content || '';\nconst contentStrategy = $('Read Content Strategy').first().json.content || '';\n\n// Current plan + SHA for update\nconst currentPlan = $('Read Current Weekly Plan').first().json.content || '';\nconst planSha = $('Read Current Weekly Plan').first().json.sha || '';\n\n// Agent reports (may not exist)\nfunction safeContent(nodeName) {\n  try {\n    const node = $(nodeName).first();\n    if (node && !node.json.error) return node.json.content || '';\n    return '[Report not available]';\n  } catch (e) {\n    return '[Report not available]';\n  }\n}\n\nconst ceoReport = safeContent('Read CEO Report');\nconst financeReport = safeContent('Read Finance Report');\nconst comptrollerReview = safeContent('Read Comptroller Review');\nconst marketingReport = safeContent('Read Marketing Report');\nconst productReport = safeContent('Read Product Report');\nconst orchestratorReview = safeContent('Read Orchestrator Review');\nconst discoveryReport = safeContent('Read Discovery Opportunities');\n\nconst prompt = `You are the Weekly Plan Generator for The Forge. Today is ${dates.today}. You are creating next week's operational plan based on all agent reports from this past week.\n\n## Current State\n${state}\n\n## Current Strategy\n${strategy}\n\n## Content Strategy\n${contentStrategy}\n\n## This Week's Agent Reports\n### CEO Reports\n${ceoReport}\n\n### Finance Reports\n${financeReport}\n\n### Comptroller Review\n${comptrollerReview}\n\n### Marketing Report\n${marketingReport}\n\n### Product Report\n${productReport}\n\n### Portfolio Orchestrator Review\n${orchestratorReview}\n\n### Discovery Opportunities\n${discoveryReport}\n\n## Current Weekly Plan\n${currentPlan}\n\nBased on all of the above, generate next week's operational plan. Include:\n\n1. **Priority Tasks** for each agent (CEO, Finance, Content, Marketing, Product, Support)\n2. **Key Metrics to Track** this week\n3. **Blockers & Risks** identified from reports\n4. **Strategic Pivots** if any agent flagged issues\n5. **Content Calendar** for the week (what to publish, when, where)\n6. **Product Roadmap Items** to tackle\n7. **Revenue/Growth Targets** for the week\n\nOutput the complete weekly-plan.md content.`;\n\nreturn [{\n  json: {\n    prompt,\n    planSha,\n    businessPath: dates.businessPath\n  }\n}];"
      },
